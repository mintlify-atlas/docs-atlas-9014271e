  "keyFeatures": [
    "JWT authentication with HttpOnly cookie-based refresh tokens",
    "Backtracking algorithm that finds the top 3 optimal schedule combinations",
    "Rule-based scoring system with 11 configurable rule types and priority ordering",
    "Two-phase optimization: pruning phase (hard constraints) + scoring phase (soft preferences)",
    "Full CRUD for subjects, professors, sections, and optimization rules",
    "Saved schedules for persisting preferred schedule combinations",
    "Swagger/OpenAPI interactive documentation at /docs",
    "PostgreSQL backend with Prisma ORM"
  ],
  "publicApiSurface": [
    "POST /api/auth/register",
    "POST /api/auth/login",
    "POST /api/auth/refresh",
    "POST /api/auth/logout",
    "GET/POST/PUT/DELETE /api/subjects",
    "GET/POST/PUT/DELETE /api/professors",
    "GET/POST/PUT/DELETE /api/sections",
    "GET/POST/PUT/DELETE /api/rules",
    "POST /api/scheduling/generate",
    "GET/POST/PUT/DELETE /api/saved-schedules"
  ]
